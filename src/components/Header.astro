<header class="mt-10 sm:mt-14 text-center select-none">
    <h1 class="sr-only">Panel - 个人导航页</h1>
    <div
        id="clock"
        class="text-6xl font-bold tracking-tight drop-shadow-2xl animate-fade-in-up"
        aria-label="当前时间"
        role="timer"
    >
        --:--:--
    </div>
    <p
        id="date"
        class="text-lg font-medium opacity-90 mt-0.5 animate-fade-in-up"
        style="animation-delay: 120ms"
    >
        载入中...
    </p>
    <div
        id="ip-info"
        class="mt-3 info-capsule"
        role="button"
        tabindex="0"
        aria-label="点击查看 IP 详情"
    >
        <i class="fas fa-location-dot capsule-icon" aria-hidden="true"></i>
        <span class="capsule-dot" aria-hidden="true"></span>
        <span id="ip-address" class="capsule-text">正在同步网络数据...</span>
    </div>
</header>
