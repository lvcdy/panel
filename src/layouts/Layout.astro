---
interface Props {
  title?: string;
  description?: string;
}

const { title = "Panel", description = "Panel" } =
  Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scrollbar-hide">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b1220" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://api.lvcdy.cn" crossorigin />
    <link rel="preconnect" href="https://ipapi.xxlb.org" crossorigin />
    <link rel="preconnect" href="https://t.alcy.cc" crossorigin />
    <link rel="dns-prefetch" href="https://api.lvcdy.cn" />
    <link rel="dns-prefetch" href="https://ipapi.xxlb.org" />
    <link rel="dns-prefetch" href="https://t.alcy.cc" />
  </head>
  <body
    class="relative min-h-screen antialiased bg-[#0b1220] overflow-x-hidden selection:bg-white/20"
  >
    <div class="page-aurora" aria-hidden="true"></div>
    <div class="page-vignette" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-url: none;
    --page-bg: #0b1220;
    --page-tint: rgba(15, 23, 42, 0.72);
    --page-line: rgba(255, 255, 255, 0.08);
  }

  body {
    background:
      radial-gradient(circle at 20% 10%, rgba(56, 189, 248, 0.16), transparent 28%),
      radial-gradient(circle at 80% 0%, rgba(167, 139, 250, 0.14), transparent 24%),
      radial-gradient(circle at 85% 82%, rgba(251, 191, 36, 0.08), transparent 20%),
      linear-gradient(180deg, #0b1220 0%, #0f172a 42%, #090f1c 100%);
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: var(--bg-url) center/cover no-repeat fixed;
    opacity: 0;
    transform: scale(1.05);
    z-index: -2;
    transition:
      opacity 1.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 2.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(11, 18, 32, 0.2), rgba(11, 18, 32, 0.55)),
      repeating-linear-gradient(
        135deg,
        transparent 0,
        transparent 22px,
        rgba(255, 255, 255, 0.02) 22px,
        rgba(255, 255, 255, 0.02) 23px
      );
    opacity: 0.85;
  }

  .page-aurora {
    position: fixed;
    inset: -10% -10% auto;
    height: 56vh;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(circle at 20% 35%, rgba(56, 189, 248, 0.22), transparent 28%),
      radial-gradient(circle at 55% 25%, rgba(168, 85, 247, 0.18), transparent 30%),
      radial-gradient(circle at 82% 40%, rgba(244, 114, 182, 0.12), transparent 24%);
    filter: blur(32px);
    opacity: 0.8;
  }

  .page-vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(circle at center, transparent 58%, rgba(0, 0, 0, 0.42) 100%),
      linear-gradient(180deg, rgba(11, 18, 32, 0.08), rgba(11, 18, 32, 0.4));
  }

  body.bg-loaded::before {
    opacity: 1;
    transform: scale(1);
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  html {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
    -webkit-tap-highlight-color: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    body::before {
      transition-duration: 1ms;
      transform: none;
    }
  }

  .category-toggle-btn {
    border: none;
    padding: 0;
    color: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .category-toggle-btn:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.28);
    outline-offset: 4px;
  }

  main {
    width: 100%;
  }
</style>
